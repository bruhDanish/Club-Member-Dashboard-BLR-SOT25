                    <img id="sidebar-avatar" src="./asstes/images/image copy.png" onerror="this.src='https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&q=80&w=150';" alt="Profile">
                    <div>
                        <h4 id="sidebar-name">User@1234</h4>
                        <p id="sidebar-role">Member</p>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Unified Premium Glass Floating Top Header -->
        <header class="ultraGlassHeader">
            <!-- Left Side: Dynamic Toggle and Branding -->
            <div class="ultraHeaderLeft" style="display: flex; align-items: center; gap: 15px;">
                <div class="toogle" id="sidebar-toggle-btn" style="box-shadow: none;">
                    <div class="toogleI">
                        <i class="bi bi-list"></i>
                    </div>
                </div>
                <div class="mainlogofitness">
                    <h1>ELEVATE FITNESS</h1>
                    <p id="header-role">Premium Member Access</p>
                </div>
            </div>

            <!-- Right Side: Notification Trigger -->
            <div class="ultraHeaderRight">
                <div class="glassNotify" id="notification-btn" aria-label="Notifications">
                    <i class="bi bi-bell" style="font-size: 1.25rem; color: #fff;"></i>
                    <span class="badge" id="notification-badge" style="display: none;"></span>
                </div>
                <!-- Notification Dropdown -->
                <div class="notification-dropdown hidden" id="notification-dropdown" style="top: 80px; right: 0;">
                    <p>No recent notifications</p>
                </div>
            </div>
        </header>

        <!-- Main Content Area -->
        <main class="main-content">
            <!-- Overview Tab (Background video, Glass metrics, and Quotes) -->
            <section id="overview-tab" class="tab-content active-content" style="padding: 0; border: none; background: transparent;">
                
                <!-- Background Classic Image Hero Header -->
                <div class="heroVideoSection" id="hero">
                    <div class="heroText">
                        <p class="hero-tagline">MEMBER DASHBOARD</p>
                        <h1><span id="dynamic-greeting">Welcome</span>, <span id="hero-username">User</span></h1>
                        <p class="hero-subtext">Real-time performance metrics for Elite Fitness today.</p>
                    </div>
                </div>

                <!-- Glass Metric Performance Cards -->
                <div class="glassCardsWrap">
                    <!-- CARD 1: Active Plan -->
                    <div class="glassCard">
                        <div class="cardIcon">
                            <i class="bi bi-star"></i>
                        </div>
                        <div class="cardContent">
                            <h1 id="active-plan-val">Basic</h1>
                            <h3>Active Plan</h3>
                            <p id="plan-type-val">New Member</p>
                        </div>
                    </div>

                    <!-- CARD 2: Total Sessions -->
                    <div class="glassCard">
                        <div class="cardTop">
                            <div class="cardIcon">
                                <i class="bi bi-activity"></i>
                            </div>
                            <div class="smallTag" id="sessions-trend-tag">
                                +3 this week
                            </div>
                        </div>
                        <div class="cardContent">
                            <h1 id="sessions-val">10 <span>.</span></h1>
                            <h3>Total Sessions</h3>
                            <p>All time</p>
                        </div>
                    </div>

                    <!-- CARD 3: Fit Points -->
                    <div class="glassCard" id="points-card">
                        <div class="cardTop">
                            <div class="cardIcon">
                                <i class="bi bi-lightning"></i>
                            </div>
                            <div class="smallTag live">
                                Live
                            </div>
                        </div>
                        <div class="cardContent">
                            <h1 id="rewards-val">0 <span>.</span></h1>
                            <h3>Fit Points</h3>
                            <p>Points earned</p>
                        </div>
                    </div>

                    <!-- CARD 4: Expiry Countdown -->
                    <div class="glassCard" id="expiry-card">
                        <div class="cardIcon">
                            <i class="bi bi-calendar3"></i>
                        </div>
                        <div class="cardContent" id="expiry-card-content">
                            <h1 id="expiry-val">Dec 31</h1>
                            <h3>Expiry Date</h3>
                            <p id="expiry-year-val">2025</p>
                        </div>
                    </div>
                </div>

                <!-- Dynamic Member Profile Details Card -->
                <div class="profileDetailsCard" id="member-profile-card">
                    <div class="profileCardHeader">
                        <h2>Profile</h2>
                        <p>Member details</p>
                    </div>
                    <div class="profileDetailsGrid">
                        <div class="profileDetailItem">
                            <p class="detailLabel">Age</p>
                            <h3 id="prof-age">--</h3>
                        </div>
                        <div class="profileDetailItem">
                            <p class="detailLabel">Height</p>
                            <h3 id="prof-height">--</h3>
                        </div>
                        <div class="profileDetailItem">
                            <p class="detailLabel">Weight</p>
                            <h3 id="prof-weight">--</h3>
                        </div>
                        <div class="profileDetailItem">
                            <p class="detailLabel">Goal</p>
                            <h3 id="prof-goal">--</h3>
                        </div>
                        <div class="profileDetailItem">
                            <p class="detailLabel">Member ID</p>
                            <h3 id="prof-id">--</h3>
                        </div>
                        <div class="profileDetailItem">
                            <p class="detailLabel">Retention</p>
                            <h3 id="prof-retention">--</h3>
                        </div>
                    </div>
                </div>

                <!-- Motivational Quotes Grid -->
                <section class="quoteGridSection">
                    <!-- Quote 1 -->
                    <div class="quoteCard">
                        <div class="quoteImage">
                            <img src="https://images.unsplash.com/photo-1517838277536-f5f99be501cd?auto=format&fit=crop&q=80&w=600" onerror="this.src='./asstes/images/specailimage4.png';" alt="Discipline Focus">
                        </div>
                        <div class="quoteContent">
                            <p>Discipline is choosing between what you want now and what your future self demands.</p>
                        </div>
                    </div>

                    <!-- Quote 2 -->
                    <div class="quoteCard">
                        <div class="quoteImage">
                            <img src="https://images.unsplash.com/photo-1541534741688-6078c6bfb5c5?auto=format&fit=crop&q=80&w=600" onerror="this.src='./asstes/images/gymimg3.png';" alt="Growth Effort">
                        </div>
                        <div class="quoteContent">
                            <p>Comfort is silent. Growth sounds like heavy breathing, failed attempts, and another repetition.</p>
                        </div>
                    </div>

                    <!-- Quote 3 -->
                    <div class="quoteCard">
                        <div class="quoteImage">
                            <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?auto=format&fit=crop&q=80&w=600" onerror="this.src='./asstes/images/SpecialGymImgae.png';" alt="Forging Strength">
                        </div>
                        <div class="quoteContent">
                            <p>The strongest people are forged when quitting becomes seductive.</p>
                        </div>
                    </div>

                    <!-- Quote 4 -->
                    <div class="quoteCard">
                        <div class="quoteImage">
                            <img src="https://images.unsplash.com/photo-1583454110551-21f2fa2afe61?auto=format&fit=crop&q=80&w=600" onerror="this.src='./asstes/images/specialIMagegym.png';" alt="Mindset over Matter">
                        </div>
                        <div class="quoteContent">
                            <p>Your body hears everything your mind says. Stop teaching it weakness.</p>
                        </div>
                    </div>
                </section>
            </section>

            <!-- Analytics Section -->
            <section id="analytics-tab" class="tab-content hidden" style="padding: 0;">
                <div class="dashboard-content-shift">
                    <div class="space-y-6 max-w-[1600px] mx-auto w-full">
                        
                        <!-- Banner Section -->
                        <section class="analytics-banner">
                            <div class="absolute inset-0 opacity-15 pointer-events-none">
                                <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?auto=format&fit=crop&q=80&w=1000" alt="" class="w-full h-full object-cover">
                            </div>
                            <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
                                <div>
                                    <h1 class="text-2xl sm:text-3xl font-bold mb-2">Membership Analysis</h1>
                                    <p class="text-sm max-w-md">Real-time engagement metrics and facility performance across all active zones.</p>
                                </div>
                                <div class="timeframe-selector flex p-1 rounded-xl self-start md:self-center">
                                    <button onclick="changeTimeframe('weekly', this)" class="filter-btn px-4 py-2 text-xs font-semibold rounded-lg transition-all cursor-pointer">Weekly</button>
                                    <button onclick="changeTimeframe('monthly', this)" class="filter-btn px-4 py-2 text-xs font-semibold rounded-lg transition-all cursor-pointer">Monthly</button>
                                    <button onclick="changeTimeframe('yearly', this)" class="filter-btn active px-4 py-2 text-xs font-semibold rounded-lg transition-all cursor-pointer">Yearly</button>
                                </div>
                            </div>
                        </section>

                        <!-- Top Grid -->
                        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                            <!-- Large Chart distribution -->
                            <div class="lg:col-span-2 glass-card rounded-3xl p-6">
                                <div class="flex justify-between items-start mb-6">
                                    <div>
                                        <h3 class="font-bold text-lg">Active Minutes</h3>
                                        <p class="text-xs text-muted">Workout duration in minutes</p>
                                    </div>
                                    <div class="text-right">
                                        <span class="text-xs text-green-500 font-bold">↗️ 12%</span>
                                    </div>
                                </div>
                                <div class="chart-container" style="height: 300px; min-height: 300px; position: relative;">
                                    <canvas id="attendanceChart"></canvas>
                                </div>
                            </div>

                            <!-- Capacity Card -->
                            <div class="flex flex-col gap-6">
                                <div class="glass-card rounded-3xl p-6 flex-1 flex flex-col justify-center">
                                    <h3 class="text-sm font-medium text-muted mb-2 uppercase tracking-widest">Goal Progress</h3>
                                    <div class="text-5xl sm:text-6xl font-bold gold-gradient-text" id="capacity-val">65%</div>
                                    <div class="mt-4 flex items-center gap-2 text-sm text-green-500">
                                        <span>↑ 5%</span>
                                        <span class="text-muted">vs last period</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Middle Row -->
                        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                            <!-- Exercise Breakdown -->
                            <div class="glass-card rounded-3xl p-6">
                                <h3 class="text-sm font-semibold mb-4">Exercise Breakdown</h3>
                                <div class="relative" style="height: 180px; position: relative;">
                                    <canvas id="analyticsUsageChart"></canvas>
                                </div>
                            </div>

                            <!-- Session Distribution Bar Chart -->
                            <div class="glass-card rounded-3xl p-6">
                                <h3 class="font-bold mb-4">Session Distribution</h3>
                                <div class="" style="height: 160px; position: relative;">
                                    <canvas id="sessionChart"></canvas>
                                </div>
                                <p class="text-xs text-muted mt-4 leading-relaxed"><i class="fa-regular fa-lightbulb text-amber-500 mr-1"></i> Peak activity shows most members sustain training sessions between 60 to 90 minutes.</p>
                            </div>

                            <!-- Stats Quick View -->
                            <div class="grid grid-cols-1 gap-4">
                                <div class="glass-card rounded-2xl p-4 flex items-center gap-4">
                                    <div class="w-12 h-12 bg-zinc-800 rounded-xl flex items-center justify-center text-xl" style="background-color: var(--bg-color); width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 12px;">🕒</div>
                                    <div>
                                        <p class="text-muted text-[10px] uppercase font-bold tracking-wider">Avg. Time</p>
                                        <h4 class="text-xl font-bold" id="stat-avg-time">1h 20m</h4>
                                    </div>
                                </div>
                                <div class="glass-card rounded-2xl p-4 flex items-center gap-4">
                                    <div class="w-12 h-12 bg-zinc-800 rounded-xl flex items-center justify-center text-xl" style="background-color: var(--bg-color); width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 12px;">🔥</div>
                                    <div>
                                        <p class="text-muted text-[10px] uppercase font-bold tracking-wider">Total Burn</p>
                                        <h4 class="text-xl font-bold" id="stat-calories">420,000</h4>
                                    </div>
                                </div>
                                <div class="glass-card rounded-2xl p-4 flex items-center gap-4">
                                    <div class="w-12 h-12 bg-zinc-800 rounded-xl flex items-center justify-center text-xl" style="background-color: var(--bg-color); width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 12px;">❤️</div>
                                    <div>
                                        <p class="text-muted text-[10px] uppercase font-bold tracking-wider">Consistency</p>
                                        <h4 class="text-xl font-bold" id="stat-retention">89%</h4>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Progress Card -->
                        <div class="glass-card rounded-3xl p-6">
                            <h3 class="font-bold mb-6 flex items-center gap-2">
                                <span>🚩</span> Personal Milestones
                            </h3>
                            
                            <div class="space-y-6">
                                <div class="space-y-2">
                                    <div class="flex justify-between text-xs font-medium">
                                        <span class="text-muted">Calories Burned</span>
                                        <span id="label-cal" class="font-semibold" style="color: var(--text-color);">420k / 500k</span>
                                    </div>
                                    <div class="h-2 rounded-full overflow-hidden" style="height: 8px; background-color: var(--bg-color); border-radius: 9999px;">
                                        <div id="bar-cal" class="h-full bg-[#d4af37] shadow-[0_0_10px_rgba(212,175,55,0.4)] transition-all duration-1000" style="width: 84%; height: 100%;"></div>
                                    </div>
                                </div>

                                <div class="space-y-2">
                                    <div class="flex justify-between text-xs font-medium">
                                        <span class="text-muted">Weight Goal</span>
                                        <span id="label-weight" class="font-semibold" style="color: var(--text-color);">15 / 20 kg</span>
                                    </div>
                                    <div class="h-2 rounded-full overflow-hidden" style="height: 8px; background-color: var(--bg-color); border-radius: 9999px;">
                                        <div id="bar-weight" class="h-full bg-[#e8ddcb] shadow-[0_0_10px_rgba(232,221,203,0.4)] transition-all duration-1000" style="width: 75%; height: 100%;"></div>
                                    </div>
                                </div>

                                <div class="space-y-2">
                                    <div class="flex justify-between text-xs font-medium">
                                        <span class="text-muted">Monthly Hours</span>
                                        <span id="label-time" class="font-semibold" style="color: var(--text-color);">50 / 60h</span>
                                    </div>
                                    <div class="h-2 rounded-full overflow-hidden" style="height: 8px; background-color: var(--bg-color); border-radius: 9999px;">
                                        <div id="bar-time" class="h-full bg-[#c27a3f] shadow-[0_0_10px_rgba(194,122,63,0.4)] transition-all duration-1000" style="width: 83%; height: 100%;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Settings Section -->
            <section id="settings-tab" class="tab-content hidden">
                <div class="dashboard-content-shift">
                    <div class="settings-container">
                        <div class="settings-card">
                            <h3>Profile Settings</h3>
                            <form class="settings-form" onsubmit="event.preventDefault();">
                                <div class="form-group">
                                    <label for="fullName">Name</label>
                                    <input type="text" id="fullName" value="User 134" class="form-input">
                                </div>
                                <div class="form-group">
                                    <label for="email">Email</label>
                                    <input type="email" id="email" value="user134@fitindia.com" class="form-input">
                                </div>
                                <button class="btn btn-light">Save Changes</button>
                            </form>
                        </div>

                        <div class="settings-card">
                            <h3>Notification Preferences</h3>
                            <div class="preference-item">
                                <div class="pref-info">
                                    <h4 class="text-uppercase">EMAIL ALERTS</h4>
                                </div>
                                <label class="switch">
                                    <input type="checkbox" checked>
                                    <span class="slider round"></span>
                                </label>
                            </div>
                            <div class="preference-item">
                                <div class="pref-info">
                                    <h4 class="text-uppercase">SESSION REMINDERS</h4>
                                </div>
                                <label class="switch">
                                    <input type="checkbox" checked>
                                    <span class="slider round"></span>
                                </label>
                            </div>
                        </div>

                        <div class="settings-card danger-zone">
                            <h3>Account & Display Options</h3>
                            
                            <div class="preference-item" style="border-bottom: 1px solid var(--border-color); margin-bottom: 1.5rem; padding-bottom: 1.5rem;">
                                <div class="pref-info">
                                    <h4 class="text-uppercase">DARK MODE</h4>
                                </div>
                                <label class="switch">
                                    <input type="checkbox" id="theme-toggle" checked>
                                    <span class="slider round"></span>
                                </label>
                            </div>

                            <div class="action-buttons">
                                <button id="logout-btn" class="btn btn-outline">Log Out</button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- ================= MEMBERSHIP MODAL ================= -->
    <div class="membershipModal">
        <div class="membershipBox">
            <button class="closeMembership" aria-label="Close modal">
                <i class="bi bi-x-lg"></i>
            </button>

            <h1>Choose Your Fitness Plan</h1>
            <p class="subText">Upgrade and unlock premium fitness features</p>

            <div class="planWrap">
                <!-- BASIC -->
                <div class="planCard" data-plan="Basic">
                    <h2>Basic</h2>
                    <div class="price">
                        ₹999<span>/month</span>
                    </div>
                    <ul>
                        <li>✔ Gym Floor Access</li>
                        <li>✔ Cardio Zone Access</li>
                        <li>✔ Locker Facility</li>
                        <li>✔ 1 Trainer Consultation</li>
                        <li>✘ Personal Coach</li>
                        <li>✘ Diet Plan</li>
                    </ul>
                    <button class="select-plan-btn">Select Plan</button>
                </div>

                <!-- ADVANCED -->
                <div class="planCard activePlan" data-plan="Advanced">
                    <div class="popularTag">MOST POPULAR</div>
                    <h2>Advanced</h2>
                    <div class="price">
                        ₹2499<span>/month</span>
                    </div>
                    <ul>
                        <li>✔ Unlimited Gym Access</li>
                        <li>✔ Group Training Sessions</li>
                        <li>✔ Weekly Fitness Assessment</li>
                        <li>✔ Customized Diet Guide</li>
                        <li>✔ Steam & Shower Access</li>
                        <li>✘ Dedicated Personal Trainer</li>
                    </ul>
                    <button class="select-plan-btn">Select Plan</button>
                </div>

                <!-- PREMIUM -->
                <div class="planCard" data-plan="Premium">
                    <h2>Premium</h2>
                    <div class="price">
                        ₹4999<span>/month</span>
                    </div>
                    <ul>
                        <li>✔ Dedicated Personal Trainer</li>
                        <li>✔ AI Progress Tracking</li>
                        <li>✔ Personalized Meal Plan</li>
                        <li>✔ Unlimited Group Sessions</li>
                        <li>✔ Recovery & Spa Access</li>
                        <li>✔ VIP Fitness Lounge</li>
                    </ul>
                    <button class="select-plan-btn">Select Plan</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Application Scripts -->
    <script src="js/data.js"></script>
    <script src="js/tabs.js"></script>
    <script src="js/theme.js"></script>
    <script src="js/charts.js"></script>
    <script src="js/app.js"></script>
</body>
</html>
