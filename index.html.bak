<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elevate Fitness | Member Access & Performance Dashboard</title>
    <meta name="description" content="Premium fitness tracking, member analytics, and real-time training dashboard.">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome & Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="css/styles.css">
    <!-- Tailwind CSS with custom config to disable Preflight -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            corePlugins: {
                preflight: false,
            }
        }
    </script>
    <style>
        html {
            scroll-behavior: smooth;
        }

        /* SCOPED LANDING PAGE SYSTEM */
        #landing-page-container {
            --bg:#080808;--surf:#141414;--border:rgba(255,255,255,0.07);--text:#f0ede0;--text2:#888580;--text3:#4a4845;--accent:#e8972a;--accent-glow:rgba(232,151,42,0.25);
            background: var(--bg);
            color: var(--text);
            font-family: 'Inter', sans-serif;
            transition: background .3s, color .3s;
            overflow-x: hidden;
            width: 100%;
            min-height: 100vh;
        }
        #landing-page-container .shine{background:linear-gradient(135deg,#ffffff 0%,#e8e0d0 40%,#ffffff 70%,#e8e0d0 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;background-size:200% auto;animation:shineMove 5s linear infinite}
        #landing-page-container .shine-static{background:linear-gradient(135deg,#ffffff 0%,#e0d8c8 50%,#ffffff 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        @keyframes shineMove{0%{background-position:0% center}100%{background-position:200% center}}
        [data-theme=light] #landing-page-container {--bg:#f5f0e8;--surf:rgba(255,255,255,0.90);--border:rgba(0,0,0,0.08);--text:#1a1814;--text2:#6a6560;--text3:#a09890;--accent:#c07820;--accent-glow:rgba(192,120,32,0.20)}
        [data-theme=light] #landing-page-container .sh{background:linear-gradient(135deg,#1a1814 0%,#3a2e20 50%,#1a1814 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        [data-theme=light] #landing-page-container .feat-title{color:#1a1814!important;background:none;-webkit-text-fill-color:initial}
        [data-theme=light] #landing-page-container .stag{color:var(--accent)!important}
        [data-theme=light] #landing-page-container .section{background:#f0ece4}
        [data-theme=light] #landing-page-container .cta-sec{background:#e8e4dc}
        [data-theme=light] #landing-page-container .feat-card{background:rgba(255,255,255,0.85);border-color:rgba(0,0,0,0.08);box-shadow:0 2px 12px rgba(0,0,0,0.06)}
        [data-theme=light] #landing-page-container .hero-eyebrow{background:rgba(0,0,0,0.06);border-color:rgba(0,0,0,0.12);color:var(--text2)}
        #landing-page-container *, #landing-page-container *::before, #landing-page-container *::after{box-sizing:border-box;margin:0;padding:0}
        
        #landing-page-container .announce{background:#1a1814;border-bottom:1px solid rgba(255,255,255,0.06);height:38px;display:flex;align-items:center;justify-content:center;gap:12px;font-size:12px;font-weight:600;color:rgba(255,255,255,0.55);letter-spacing:.5px}
        #landing-page-container .announce a{color:var(--accent);text-decoration:none;border-bottom:1px solid rgba(232,151,42,0.4);cursor:pointer;transition:color .2s}
        #landing-page-container nav{position:sticky;top:0;z-index:100;height:64px;background:rgba(8,8,8,0.88);backdrop-filter:blur(24px) saturate(160%);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 48px;gap:8px;transition:background .3s}
        [data-theme=light] #landing-page-container nav{background:rgba(245,240,232,0.90)}
        #landing-page-container .nav-brand{display:flex;align-items:center;gap:10px;text-decoration:none;margin-right:16px}
        #landing-page-container .nav-icon{width:34px;height:34px;background:var(--accent);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;color:#1a1a1a;}
        #landing-page-container .nav-name{font-family:'Bebas Neue',sans-serif;font-size:19px;letter-spacing:2.5px;color:var(--text)}
        #landing-page-container .nav-link{font-size:13px;font-weight:500;color:var(--text2);text-decoration:none;padding:6px 14px;border-radius:8px;transition:color .2s,background .2s}
        #landing-page-container .nav-link:hover{color:var(--text);background:var(--border)}
        #landing-page-container .nav-right{margin-left:auto;display:flex;align-items:center;gap:12px}
        #landing-page-container .theme-pill{display:inline-flex;align-items:center;gap:8px;background:var(--surf);border:1px solid var(--border);border-radius:20px;padding:4px 14px 4px 5px;cursor:pointer;transition:all .2s;user-select:none}
        #landing-page-container .theme-pill:hover{border-color:rgba(232,151,42,0.40)}
        #landing-page-container .theme-knob{width:26px;height:26px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:13px;transition:transform .3s,background .3s;color:#1a1a1a;}
        #landing-page-container .theme-pill-lbl{font-size:11px;font-weight:600;color:var(--text2);letter-spacing:.5px;width:30px}
        #landing-page-container .btn-nav-login{background:var(--text);color:var(--bg);border:none;border-radius:9px;padding:8px 20px;font-family:'Inter',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:opacity .2s,transform .15s;letter-spacing:.3px}
        #landing-page-container .btn-nav-login:hover{opacity:.85;transform:translateY(-1px)}
        #landing-page-container .hero{min-height:100vh;position:relative;display:flex;flex-direction:column;justify-content:center;overflow:hidden}
        #landing-page-container .hero-bg{position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1920&q=85') center/cover no-repeat}
        #landing-page-container .hero-overlay{position:absolute;inset:0;background:linear-gradient(105deg,rgba(8,8,8,0.88) 0%,rgba(8,8,8,0.60) 50%,rgba(8,8,8,0.30) 100%)}
        #landing-page-container .hero-overlay2{position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,1) 0%,transparent 40%)}
        [data-theme=light] #landing-page-container .hero-overlay{background:linear-gradient(105deg,rgba(8,8,8,0.82) 0%,rgba(8,8,8,0.55) 50%,rgba(8,8,8,0.20) 100%)}
        [data-theme=light] #landing-page-container .hero-overlay2{background:linear-gradient(to top,var(--bg) 0%,transparent 40%)}
        #landing-page-container .hero-content{position:relative;z-index:2;padding:0 80px;max-width:860px}
        #landing-page-container .hero-eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);border-radius:20px;padding:6px 16px;margin-bottom:28px;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.70)}
        #landing-page-container .hero-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:blink 2s infinite}
        @keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
        #landing-page-container .hero h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(70px,11vw,130px);letter-spacing:3px;line-height:.92;color:#ffffff;margin-bottom:10px}
        #landing-page-container .hero h1 .hl{background:linear-gradient(135deg,#ffffff 0%,#e8e0d0 40%,#ffffff 80%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;background-size:200% auto;animation:shineMove 5s linear infinite;display:inline-block}
        #landing-page-container .hero-sub-line{font-family:'Bebas Neue',sans-serif;font-size:clamp(36px,5vw,60px);letter-spacing:3px;color:rgba(255,255,255,0.14);margin-bottom:28px}
        #landing-page-container .hero-desc{font-size:17px;line-height:1.75;color:rgba(255,255,255,0.62);max-width:480px;margin-bottom:40px;font-weight:300}
        #landing-page-container .hero-btns{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:60px}
        #landing-page-container .btn-primary{background:var(--accent);color:#1a1a1a;border:none;border-radius:12px;padding:16px 38px;font-family:'Bebas Neue',sans-serif;font-size:21px;letter-spacing:2px;cursor:pointer;transition:transform .15s,box-shadow .2s;box-shadow:0 8px 32px var(--accent-glow)}
        #landing-page-container .btn-primary:hover{transform:translateY(-3px);box-shadow:0 16px 48px var(--accent-glow)}
        #landing-page-container .btn-outline{background:rgba(255,255,255,0.06);color:#fff;border:1px solid rgba(255,255,255,0.22);border-radius:12px;padding:16px 38px;font-family:'Bebas Neue',sans-serif;font-size:21px;letter-spacing:2px;cursor:pointer;backdrop-filter:blur(10px);transition:all .2s}
        #landing-page-container .btn-outline:hover{background:rgba(255,255,255,0.12);transform:translateY(-3px)}
        #landing-page-container .hero-stats{display:flex;gap:48px;padding:28px 0;border-top:1px solid rgba(255,255,255,0.08);position:relative;z-index:2;padding-left:80px}
        #landing-page-container .hstat-num{font-family:'Bebas Neue',sans-serif;font-size:42px;letter-spacing:1.5px;color:#ffffff;text-shadow:0 0 20px rgba(255,255,255,0.15)}
        #landing-page-container .hstat-lbl{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,0.40);margin-top:2px}
        #landing-page-container .section{padding:96px 80px;background:var(--bg)}
        #landing-page-container .stag{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,0.40);font-weight:700;margin-bottom:10px}
        #landing-page-container .sh{font-family:'Bebas Neue',sans-serif;font-size:clamp(40px,5vw,64px);letter-spacing:2px;margin-bottom:14px;background:linear-gradient(135deg,#ffffff 0%,#e8e0d0 50%,#ffffff 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        #landing-page-container .ssub{font-size:15px;color:var(--text2);max-width:480px;line-height:1.75;margin-bottom:56px}
        #landing-page-container .feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
        #landing-page-container .feat-card{background:var(--surf);border:1px solid var(--border);border-radius:16px;padding:30px 26px;transition:all .2s;position:relative;overflow:hidden}
        #landing-page-container .feat-card::before{content:'';position:absolute;top:-60px;right:-60px;width:140px;height:140px;border-radius:50%;background:var(--accent-glow);opacity:0;transition:opacity .3s}
        #landing-page-container .feat-card:hover{transform:translateY(-4px);border-color:rgba(255,255,255,0.12);box-shadow:0 12px 40px rgba(0,0,0,0.5)}
        #landing-page-container .feat-card:hover::before{opacity:.5}
        #landing-page-container .feat-icon{font-size:30px;margin-bottom:16px}
        #landing-page-container .feat-title{font-family:'Bebas Neue',sans-serif;font-size:21px;letter-spacing:1.5px;margin-bottom:9px;color:#f0ede0}
        #landing-page-container .feat-desc{font-size:13px;color:var(--text2);line-height:1.7}
        #landing-page-container .split{display:grid;grid-template-columns:1fr 1fr;overflow:hidden}
        #landing-page-container .split-img{background:url('https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=900&q=85') center/cover;min-height:480px}
        #landing-page-container .split-body{background:#0f0d0a;padding:80px 60px;display:flex;flex-direction:column;justify-content:center}
        [data-theme=light] #landing-page-container .split-body{background:#1a1612}
        #landing-page-container .check-list{list-style:none;display:flex;flex-direction:column;gap:14px;margin-top:8px}
        #landing-page-container .check-list li{display:flex;align-items:center;gap:12px;font-size:14px;color:rgba(240,237,224,0.60)}
        #landing-page-container .check-list li::before{content:'✓';color:var(--accent);font-weight:700;font-size:15px;flex-shrink:0}
        #landing-page-container .marquee-section{background:#0f0d0a;padding:48px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);overflow:hidden}
        [data-theme=light] #landing-page-container .marquee-section{background:#1a1612}
        #landing-page-container .marquee-label{text-align:center;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--text3);margin-bottom:28px}
        #landing-page-container .marquee-track{display:flex;gap:32px;animation:marquee 24s linear infinite;width:max-content}
        @keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
        #landing-page-container .marquee-item{display:flex;align-items:center;gap:10px;background:var(--surf);border:1px solid var(--border);border-radius:40px;padding:10px 18px 10px 10px;flex-shrink:0}
        #landing-page-container .m-av{width:32px;height:32px;border-radius:50%;background:var(--accent-glow);color:var(--accent);font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;border:2px solid rgba(232,151,42,0.30)}
        #landing-page-container .m-name{font-size:12px;font-weight:600;color:var(--text)}
        #landing-page-container .m-goal{font-size:10px;color:var(--text3)}
        #landing-page-container .cta-sec{padding:96px 80px;text-align:center;background:var(--bg)}
        #landing-page-container .cta-inner{max-width:680px;margin:0 auto}
        #landing-page-container .cta-glow{width:280px;height:280px;border-radius:50%;background:rgba(232,151,42,0.08);filter:blur(80px);position:absolute;left:50%;transform:translateX(-50%);pointer-events:none;opacity:.6}
        #landing-page-container .cta-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:36px}
        #landing-page-container footer{background:#050505;border-top:1px solid var(--border);padding:36px 80px;display:flex;align-items:center;justify-content:space-between}
        #landing-page-container .foot-brand{font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:3px;color:var(--text3)}
        #landing-page-container .foot-copy{font-size:11px;color:var(--text3)}
        @media(max-width:900px){
          #landing-page-container .hero-content{padding:0 32px}
          #landing-page-container .hero-stats{padding-left:32px;gap:28px;flex-wrap:wrap}
          #landing-page-container .section{padding:64px 32px}
          #landing-page-container .feat-grid{grid-template-columns:1fr}
          #landing-page-container .split{grid-template-columns:1fr}
          #landing-page-container .split-img{min-height:260px}
          #landing-page-container .split-body{padding:48px 32px}
          #landing-page-container nav{padding:0 24px}
          #landing-page-container .nav-link{display:none}
          #landing-page-container footer{flex-direction:column;gap:10px;padding:28px 24px;text-align:center}
          #landing-page-container .cta-sec{padding:64px 32px}
        }
</head>
<body>
    <div id="landing-page-container">
        <div class="announce">🔥 New: Elite Annual Plans now 20% off — <a class="trigger-signup" style="cursor:pointer;">Claim yours →</a></div>

        <nav>
          <a class="nav-brand" href="#">
            <div class="nav-icon">🏋️</div>
            <span class="nav-name">Elevate Fitness</span>
          </a>
          <a class="nav-link" href="#features">Features</a>
          <a class="nav-link" href="#about">About</a>
          <a class="nav-link" href="#cta">Plans</a>
          <div class="nav-right">
            <div class="theme-pill" id="theme-toggle-landing">
              <div class="theme-knob" id="themeKnob">🌙</div>
              <span class="theme-pill-lbl" id="themeLbl">Dark</span>
            </div>
            <button class="btn-nav-login trigger-login">Login →</button>
          </div>
        </nav>

        <section class="hero">
          <div class="hero-bg"></div>
          <div class="hero-overlay"></div>
          <div class="hero-overlay2"></div>
          <div class="hero-content">
            <div class="hero-eyebrow"><div class="hero-dot"></div>10,000+ Members Training Now</div>
            <h1>PUSH<br/>YOUR <span class="hl">LIMITS</span></h1>
            <div class="hero-sub-line">NO EXCUSES. ONLY RESULTS.</div>
            <p class="hero-desc">World-class coaching, real-time performance analytics, and a community that refuses to quit. Your transformation starts the moment you walk in.</p>
            <div class="hero-btns">
              <button class="btn-primary trigger-signup">Start Free Trial</button>
              <button class="btn-outline" onclick="document.getElementById('features').scrollIntoView({behavior:'smooth'})">Explore Features</button>
            </div>
          </div>
          <div class="hero-stats">
            <div><div class="hstat-num">10K+</div><div class="hstat-lbl">Active Members</div></div>
            <div><div class="hstat-num">50+</div><div class="hstat-lbl">Expert Trainers</div></div>
            <div><div class="hstat-num">95%</div><div class="hstat-lbl">Retention Rate</div></div>
            <div><div class="hstat-num">12 Yrs</div><div class="hstat-lbl">Of Excellence</div></div>
          </div>
        </section>

        <div class="marquee-section">
          <div class="marquee-label">Our Members</div>
          <div class="marquee-track" id="marqueeTrack"></div>
        </div>

        <section class="section" id="features">
          <div class="stag">Why Elevate</div>
          <h2 class="sh">BUILT FOR CHAMPIONS</h2>
          <p class="ssub">Everything you need to train smarter, track progress, and crush your goals — all in one premium platform.</p>
          <div class="feat-grid">
            <div class="feat-card"><div class="feat-icon">📊</div><div class="feat-title">Real-Time Analytics</div><div class="feat-desc">Track every rep, calorie and session with beautiful weekly, monthly and yearly trend charts.</div></div>
            <div class="feat-card"><div class="feat-icon">🏆</div><div class="feat-title">Milestone Tracking</div><div class="feat-desc">Set goals, track progress with visual bars, and celebrate every personal record you break.</div></div>
            <div class="feat-card"><div class="feat-icon">⚡</div><div class="feat-title">Elite Membership</div><div class="feat-desc">Standard or Elite — unlock premium coaching, advanced metrics, and priority class access.</div></div>
            <div class="feat-card"><div class="feat-icon">🔥</div><div class="feat-title">Streak System</div><div class="feat-desc">Build unstoppable habits with our daily streak tracker that rewards consistent dedication.</div></div>
            <div class="feat-card"><div class="feat-icon">👤</div><div class="feat-title">Personal Dashboard</div><div class="feat-desc">Your own analytics hub — goals, plan, exercise breakdown, and retention score in one view.</div></div>
            <div class="feat-card"><div class="feat-icon">🌙</div><div class="feat-title">Dark & Light Modes</div><div class="feat-desc">Comfortable on every screen, any time of day — seamless theme switching at your fingertip.</div></div>
          </div>
        </section>

        <div class="split" id="about">
          <div class="split-img"></div>
          <div class="split-body">
            <div class="stag">Our Philosophy</div>
            <h2 class="sh">TRAIN SMARTER,<br/>NOT HARDER</h2>
            <p class="ssub" style="color:#888580;max-width:400px">Data-driven insights combined with elite coaching to push you to peak performance, sustainably.</p>
            <ul class="check-list">
              <li>Personalised workout &amp; nutrition tracking</li>
              <li>Weekly, monthly and yearly trend analysis</li>
              <li>Exercise type breakdown with doughnut charts</li>
              <li>Retention scoring and streak rewards</li>
              <li>10 pre-loaded member profiles to explore</li>
              <li>Instant dark / light mode for comfort</li>
            </ul>
          </div>
        </div>

        <section class="cta-sec" id="cta" style="position:relative;overflow:hidden">
          <div class="cta-glow"></div>
          <div class="cta-inner" style="position:relative;z-index:2">
            <div class="stag">Get Started</div>
            <h2 class="sh">READY TO ELEVATE?</h2>
            <p class="ssub" style="margin:0 auto;text-align:center">Join thousands of members transforming their lives. Your journey to peak performance starts today.</p>
            <div class="cta-btns">
              <button class="btn-primary trigger-signup">Create Free Account</button>
              <button class="btn-outline trigger-login" style="background:rgba(232,151,42,0.06);color:var(--accent);border-color:rgba(232,151,42,0.30)">Member Login</button>
            </div>
          </div>
        </section>

        <footer>
          <span class="foot-brand">Elevate Fitness</span>
          <span class="foot-copy">©️ 2026 Elevate Fitness. All rights reserved.</span>
        </footer>
    </div>
        <!-- BACKGROUND MUSIC ASSET -->
        <audio id="bg-music" src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-4.mp3" loop></audio>

        <!-- FLOATING MUSIC TOGGLE BUTTON -->
        <div class="audio-controller">
          <div class="audio-status" id="audio-status-text">MUSIC OFF</div>
          <button id="audio-toggle" class="audio-btn" title="Toggle Audio">
            <i class="fa-solid fa-volume-xmark"></i>
          </button>
        </div>

        <div class="announce" style="background: var(--accent); color: #000; text-align: center; padding: 8px 15px; font-size: 12px; font-weight: 700; letter-spacing: 0.5px; z-index: 1001; position: relative;">
            <i class="fa-solid fa-bolt" style="margin-right: 5px;"></i> <span>Welcome to the new standard.</span> <a href="#" style="color: #000; text-decoration: underline; margin-left: 5px;">Explore Elite</a>
        </div>

        <nav>
            <a href="#" class="nav-brand">
                <div class="nav-icon"><i class="fa-solid fa-dumbbell"></i></div>
                <div class="nav-name">Elite Fitness</div>
            </a>
            
            <a href="#" class="nav-link">Locations</a>
            <a href="#" class="nav-link">Personal Training</a>
            <a href="#" class="nav-link">Group Classes</a>
            <a href="#" class="nav-link">Recovery</a>

            <div class="nav-right">
                <div class="theme-pill" id="theme-toggle-landing">
                    <div class="theme-knob" id="themeKnob">🌙</div>
