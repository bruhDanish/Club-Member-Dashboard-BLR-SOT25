        <!-- AUDIO TOGGLE LOGIC SCRIPT -->
        <script>
          (function() {
            const bgMusic = document.getElementById('bg-music');
            const audioToggle = document.getElementById('audio-toggle');
            const statusText = document.getElementById('audio-status-text');
            if (bgMusic && audioToggle && statusText) {
              const icon = audioToggle.querySelector('i');
              bgMusic.volume = 0.4;
              audioToggle.addEventListener('click', () => {
                if (bgMusic.paused) {
                  bgMusic.play().then(() => {
                    if (icon) {
                      icon.className = 'fa-solid fa-volume-high';
                    }
                    statusText.innerText = "MUSIC ON";
                    audioToggle.style.background = 'white';
                    audioToggle.style.color = 'black';
                  }).catch(err => {
                    console.error("Audio playback prevented:", err);
                  });
                } else {
                  bgMusic.pause();
                  if (icon) {
                    icon.className = 'fa-solid fa-volume-xmark';
                  }
                  statusText.innerText = "MUSIC OFF";
                  audioToggle.style.background = 'rgba(0, 0, 0, 0.6)';
                  audioToggle.style.color = 'white';
                }
              });
            }
          })();
        </script>

